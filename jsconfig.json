{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "app/*": ["src/app/*"],
      "components/*": ["src/components/*"],
      "layouts/*": ["src/layouts/*"],
      "pages/*": ["src/pages/*"],
      "boot/*": ["src/boot/*"],
      "stores/*": ["src/stores/*"],
      "vue$": ["node_modules/vue/dist/vue.runtime.esm-bundler.js"]
    }
  },
  "exclude": [
    "dist",
    ".quasar",
    "node_modules",
    "src/pages/prize_results/components",
    "src/layouts/selection.vue"
  ]
  // "extends": "./.quasar/tsconfig.json"
}
